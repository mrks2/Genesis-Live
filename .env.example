# ===========================================
# Genesis Live — Backend environment variables
# ===========================================
# Copier ce fichier en `.env` et remplir les valeurs locales.
# Ne JAMAIS commiter le fichier `.env` (il est dans .gitignore).

# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

