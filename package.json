{
  "name": "genesis-live",
  "version": "0.0.0",
  "private": true,
  "description": "Simulation émergente diffusée en direct, pilotée par le chat YouTube + Twitch.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrks2/Genesis-Live.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run build -w @genesis-live/shared && concurrently -n shared,backend,frontend -c gray,blue,magenta -k \"npm run dev -w @genesis-live/shared\" \"npm run dev -w @genesis-live/backend\" \"npm run dev -w @genesis-live/frontend\"",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc --build",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "lint": "npm run lint:md",
    "clean": "tsc --build --clean && rimraf \"*/dist\" \"*/.vite\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.7.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.md": "markdownlint-cli2 --fix"
  }
}
